# API
API_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL (async URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/payments

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=120

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Outbox publisher
OUTBOX_POLL_INTERVAL_MS=200
OUTBOX_BATCH_SIZE=50

# Payment consumer / webhook
WEBHOOK_MAX_RETRIES=3
WEBHOOK_BACKOFF_BASE_SECONDS=1.0
WEBHOOK_BACKOFF_MAX_SECONDS=30.0
WEBHOOK_CONNECT_TIMEOUT_SECONDS=5.0
WEBHOOK_READ_TIMEOUT_SECONDS=15.0
WEBHOOK_CB_FAILURE_THRESHOLD=5
WEBHOOK_CB_OPEN_SECONDS=60
WEBHOOK_CB_KEY_TTL_SECONDS=300
GATEWAY_MIN_DELAY_SECONDS=2.0
GATEWAY_MAX_DELAY_SECONDS=5.0
GATEWAY_SUCCESS_PROBABILITY=0.9

# Consumer message retries before DLQ
CONSUMER_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=INFO
